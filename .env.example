# MOR DIEM SDK Configuration
# Copy to .env and fill in your values

# =============================================================================
# Gateway Mode (Recommended)
# =============================================================================
# Get your API key from https://app.mor.org
MOR_API_KEY=sk-xxxxx

# =============================================================================
# Wallet Mode (Advanced - for staking/P2P)
# =============================================================================
# BIP39 mnemonic (12 or 24 words)
# MOR_MNEMONIC="word1 word2 word3 ..."

# Wallet derivation index (default: 0)
# MOR_WALLET_INDEX=0

# =============================================================================
# Optional
# =============================================================================
# Custom RPC for Base chain
# MOR_RPC_URL=https://mainnet.base.org

# Custom API base URL (for local proxy/testing)
# MOR_BASE_URL=http://127.0.0.1:8083
