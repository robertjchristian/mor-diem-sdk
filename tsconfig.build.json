{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist"
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"release",
		"reference",
		"bin",
		"src/proxy/*.mjs",
		"src/wallet/*.mjs"
	]
}
